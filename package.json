{
  "name": "omnigent",
  "version": "1.0.0",
  "description": "OMNIGENT - Universal AI Agent Platform with 200+ commands, 19 messaging channels, multi-LLM support, webhooks, skills engine, OAuth, and REST API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/interactive-shell.js",
    "omnigent": "node src/interactive-shell.js",
    "dev": "node --watch src/index.js",
    "test": "node --test tests/**/*.test.js",
    "lint": "eslint src/",
    "build": "node scripts/build.js",
    "cli": "node src/cli.js",
    "config": "node src/config/setup.js",
    "agent": "node src/agent/omnigent.js",
    "api": "node src/api/server.js",
    "dashboard": "open src/web/dashboard.html",
    "docker-build": "docker build -t omnigent .",
    "docker-run": "docker-compose up",
    "setup": "node src/setup/cli.js"
  },
  "keywords": [
    "ai-agent",
    "omnigent",
    "claude",
    "multi-provider",
    "agent-framework"
  ],
  "author": "OmniAgent Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "dotenv": "^16.4.5",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "axios": "^1.7.7",
    "yaml": "^2.4.5",
    "ora": "^8.1.0",
    "tinyagi": "latest",
    "hermes-protocol": "latest",
    "openclaw": "latest",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "better-sqlite3": "^9.2.2"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "prettier": "^3.3.3"
  },
  "bin": {
    "omnigent-setup": "./src/setup/cli.js"
  }
}